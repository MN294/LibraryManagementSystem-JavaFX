<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lms.BooksCatalogController">
   <children>
      <TableView fx:id="booksTableView" layoutX="5.0" layoutY="72.0" prefHeight="423.0" prefWidth="639.0">
        <columns>
          <TableColumn fx:id="IDColumn" prefWidth="58.0" text="ID" />
          <TableColumn fx:id="titleCol" prefWidth="179.0" text="Title" />
            <TableColumn fx:id="authorCol" prefWidth="131.0" text="Author" />
            <TableColumn fx:id="copiesCol" prefWidth="136.0" text="Available Copies" />
            <TableColumn fx:id="ISBNCol" prefWidth="134.0" text="ISBN" />
        </columns>
      </TableView>
      <Label layoutX="20.0" layoutY="30.0" prefHeight="17.0" prefWidth="99.0" text="Books Catalog" textFill="#263f73">
         <font>
            <Font name="Adelle Sans Devanagari Extrabold" size="14.0" />
         </font>
      </Label>
      <TextField fx:id="searchTextField" layoutX="129.0" layoutY="27.0" prefHeight="26.0" prefWidth="420.0" promptText="Keywords....">
         <font>
            <Font name="Adelle Sans Devanagari Semibold" size="13.0" />
         </font>
      </TextField>
   </children>
</AnchorPane>
